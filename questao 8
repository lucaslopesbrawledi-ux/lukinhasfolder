#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <string.h>

#define PI 3.14159265358979323846

char **grid;
int ROWS, COLS;

void set_pixel(int row, int col) {
    if (row >= 0 && row < ROWS && col >= 0 && col < COLS)
        grid[row][col] = '*';
}

void draw_line(double x0, double y0, double x1, double y1) {
    int ix0 = (int)round(x0), iy0 = (int)round(y0);
    int ix1 = (int)round(x1), iy1 = (int)round(y1);

    int dx = abs(ix1 - ix0), dy = abs(iy1 - iy0);
    int sx = ix0 < ix1 ? 1 : -1;
    int sy = iy0 < iy1 ? 1 : -1;
    int err = dx - dy;

    while (1) {
        set_pixel(iy0, ix0);
        if (ix0 == ix1 && iy0 == iy1) break;
        int e2 = 2 * err;
        if (e2 > -dy) { err -= dy; ix0 += sx; }
        if (e2 <  dx) { err += dx; iy0 += sy; }
    }
}
void koch(double x0, double y0, double x1, double y1, int nivel) {
    if (nivel == 0) {
        draw_line(x0, y0, x1, y1);
        return;
    }

    double ax = x0 + (x1 - x0) / 3.0;
    double ay = y0 + (y1 - y0) / 3.0;
    double bx = x0 + 2.0 * (x1 - x0) / 3.0;
    double by = y0 + 2.0 * (y1 - y0) / 3.0;
    double mx = (ax + bx) / 2.0 - (by - ay) * sqrt(3.0) / 2.0;
    double my = (ay + by) / 2.0 + (bx - ax) * sqrt(3.0) / 2.0;

    koch(x0, y0, ax, ay, nivel - 1);
    koch(ax, ay, mx, my, nivel - 1);
    koch(mx, my, bx, by, nivel - 1);
    koch(bx, by, x1, y1, nivel - 1);
}

int main() {
    int N;

    do {
        printf("Informe o nivel N do fractal (1 a 3): ");
        scanf("%d", &N);
        if (N < 1 || N > 3)
            printf("Valor invalido! N deve ser entre 1 e 3.\n");
    } while (N < 1 || N > 3);

    int escala = 10 * (int)pow(3, N); 
    int margem = 4;

    ROWS = (int)(escala * sqrt(3.0)) + margem * 2;
    COLS = escala * 2 + margem * 2;
    grid = (char **)malloc(ROWS * sizeof(char *));
    for (int i = 0; i < ROWS; i++) {
        grid[i] = (char *)malloc((COLS + 1) * sizeof(char));
        memset(grid[i], ' ', COLS);
        grid[i][COLS] = '\0';
    }

    double cx = COLS / 2.0;
    double cy = ROWS / 2.0;
    double r  = escala / 2.0; 
    double t1[3][2], t2[3][2];
    for (int i = 0; i < 3; i++) {
        double ang1 = -PI / 2.0 + i * 2.0 * PI / 3.0;
        t1[i][0] = cx + r * cos(ang1);
        t1[i][1] = cy + r * sin(ang1);

        double ang2 = PI / 2.0 + i * 2.0 * PI / 3.0;
        t2[i][0] = cx + r * cos(ang2);
        t2[i][1] = cy + r * sin(ang2);
    }

    for (int i = 0; i < 3; i++) {
        int next = (i + 1) % 3;
        koch(t1[i][0], t1[i][1], t1[next][0], t1[next][1], N - 1);
        koch(t2[i][0], t2[i][1], t2[next][0], t2[next][1], N - 1);
    }

    printf("\n");
    for (int i = 0; i < ROWS; i++) {

        int last = COLS - 1;
        while (last >= 0 && grid[i][last] == ' ') last--;
        grid[i][last + 1] = '\0';
        printf("%s\n", grid[i]);
    }

    for (int i = 0; i < ROWS; i++) free(grid[i]);
    free(grid);

    return 0;
}
