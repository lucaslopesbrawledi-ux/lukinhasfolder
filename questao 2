#include <stdio.h>

int main() {
    int n;

    do {
        printf("digite o valor de N (tem que ser maior ou igual a 2): ");
        scanf("%d", &n);
        if (n < 2)
            printf("o N deve ser maior ou igual a 2.\n");
    } while (n < 2);

    printf("\n");

    for (int i = 1; i <= n; i++) {
        for (int s = 0; s < (n - i) * 2; s++) {
            printf(" ");
        }

        for (int j = 1; j <= i; j++) {
            printf("%d ", j);
        }

        for (int j = i - 1; j >= 1; j--) {
            printf("%d ", j);
        }

        printf("\n\n");
    }

    return 0;
}
