#include <stdio.h>

int main() {
    int largura;

    do {
        printf("digite a largura central do losango (numero impar >= 1): ");
        scanf("%d", &largura);
        if (largura < 1 || largura % 2 == 0)
            printf("invalido, digita um numero impar maior ou igual a 1.\n");
    } while (largura < 1 || largura % 2 == 0);

    printf("\n");

    int meio = largura / 2;

    for (int i = 0; i <= meio; i++) {
        int xs = 2 * i + 1;
        int espacos = meio - i; 

        for (int s = 0; s < espacos; s++)
            printf(" ");
        for (int j = 0; j < xs; j++)
            printf("X");
        printf("\n");
    }

    // Metade inferior
    for (int i = meio - 1; i >= 0; i--) {
        int xs = 2 * i + 1;
        int espacos = meio - i;

        for (int s = 0; s < espacos; s++)
            printf(" ");
        for (int j = 0; j < xs; j++)
            printf("X");
        printf("\n");
    }

    return 0;
}
